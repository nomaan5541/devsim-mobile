{"index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Jagged Crown: css math</title>\n    <link rel=\"stylesheet\" href=\"./style.css\">\n\n  </head>\n    \n  <body>\n  <div class=\"cont\">\n  <div class=\"grad\">\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n    <div class=\"card\"></div>\n  </div>\n</div>\n<!--disclaimer: uses corner-shape-->\n    \n  </body>\n  \n</html>\n", "style.css": "div {\n  transform-style: preserve-3d;\n  box-sizing: padding-box;\n}\n\n.grad {\n  --r: 80vmin;\n  position: relative;\n  width: var(--r);\n  aspect-ratio: 1;\n  border-radius: 100vmax;\n  animation: z360 30s linear infinite;\n}\n\n.grad .card {\n  position: absolute;\n  offset-path: border-box;\n  offset-distance: calc(sibling-index() / sibling-count() * 100%);\n  transform: rotatex(90deg);\n  border: 1px solid #F5F5F0;\n  border-width: 5px 0px;\n  width: 1rem;\n  width: calc(2 * pi * var(--r) / sibling-count());\n  height: 2rem;\n  display: grid;\n  place-content: center;\n  background: hsl(calc(sibling-index() * 360 / sibling-count()), 75%, 75%);\n  border-radius: 50%;\n  corner-shape: bevel;\n}\n\nbody {\n  background: #1f2020;\n  font-family: system-ui, sans-serif;\n  margin: 0;\n  min-height: 100vh;\n  display: grid;\n  place-content: center;\n}\n\n@keyframes z360 {\n  0% {\n    transform: rotatex(-125deg) rotatez(0deg);\n  }\n  50% {\n    transform: rotatex(-60deg) rotatez(-180deg);\n  }\n  100% {\n    transform: rotatex(-125deg) rotatez(-360deg);\n  }\n}"}