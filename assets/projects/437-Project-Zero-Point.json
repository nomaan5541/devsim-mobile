{"index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>PROJECT: ZERO-POINT</title>\n    \n\n  </head>\n    \n  <body>\n  <!--- Created By: Justin Linwood Ross. Copyright: 2025 --->\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PROJECT: ZERO-POINT | REDUX</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;500;700&display=swap');\n\n        body {\n            margin: 0; overflow: hidden; background-color: #000;\n            font-family: 'Rajdhani', sans-serif; color: #aeeeff; user-select: none;\n        }\n\n        #canvas-container { width: 100vw; height: 100vh; position: absolute; top: 0; left: 0; z-index: 1; }\n\n        /* UI OVERLAY */\n        #ui-layer {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none;\n            background: radial-gradient(circle at center, transparent 40%, #000510 140%);\n        }\n\n        .hud-element { position: absolute; text-transform: uppercase; letter-spacing: 2px; text-shadow: 0 0 10px rgba(0, 255, 255, 0.7); }\n\n        .top-left { top: 30px; left: 30px; border-left: 3px solid #00ffff; padding-left: 15px; }\n        .top-left h1 { font-size: 28px; margin: 0; font-weight: 700; color: #fff; }\n        .top-left p { font-size: 12px; opacity: 0.8; color: cyan; margin-top: 5px; }\n\n        .bottom-right { bottom: 30px; right: 30px; text-align: right; border-right: 3px solid #00ffff; padding-right: 15px; }\n        .metric { font-size: 32px; font-weight: 300; }\n        .label { font-size: 10px; color: #597d8a; margin-top: 5px; }\n\n        .controls {\n            position: absolute; bottom: 30px; left: 30px; pointer-events: auto;\n            background: rgba(0, 10, 20, 0.8); padding: 20px; border: 1px solid #00ffff;\n            backdrop-filter: blur(5px); z-index: 10;\n        }\n        \n        button {\n            background: rgba(0, 255, 255, 0.1); border: 1px solid #00ffff; color: #00ffff;\n            padding: 10px 20px; font-family: 'Rajdhani'; font-weight: 700; cursor: pointer;\n            transition: all 0.3s; width: 100%; margin-bottom: 10px; letter-spacing: 1px;\n        }\n        button:hover { background: #00ffff; color: #000; box-shadow: 0 0 15px #00ffff; }\n\n        input[type=range] { width: 100%; margin: 10px 0; accent-color: #00ffff; }\n\n        .scanlines {\n            position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 3; opacity: 0.15;\n            background: linear-gradient(to bottom, rgba(255,255,255,0) 50%, rgba(0,0,0,0.2) 50%); background-size: 100% 4px;\n        }\n        \n        /* Debug / Loading Overlay */\n        #debug-screen {\n            position: absolute; top:0; left:0; width:100%; height:100%; background:#000; z-index: 999;\n            display:flex; flex-direction:column; justify-content:center; align-items:center; color:cyan;\n            font-family: monospace;\n        }\n        #status-log { color: #00ffff; margin-bottom: 10px; }\n        #error-msg { color: #ff3333; margin-top: 10px; max-width: 80%; text-align: center; }\n    </style>\n\n    <script type=\"importmap\">\n        {\n            \"imports\": {\n                \"three\": \"https://esm.sh/three@0.160.0\",\n                \"three/addons/\": \"https://esm.sh/three@0.160.0/examples/jsm/\",\n                \"cannon-es\": \"https://esm.sh/cannon-es@0.20.0\"\n            }\n        }\n    </script>\n</head>\n<body>\n\n    <div id=\"debug-screen\">\n        <div id=\"status-log\">INITIALIZING CONNECTION...</div>\n        <div id=\"error-msg\"></div>\n    </div>\n\n    <div id=\"canvas-container\"></div>\n    <div class=\"scanlines\"></div>\n\n    <div id=\"ui-layer\">\n        <div class=\"hud-element top-left\">\n            <h1>PROJECT: ZERO-POINT</h1>\n            <p>PHYSICS: STABLE | SYSTEM: ONLINE</p>\n        </div>\n        \n        <div class=\"controls\">\n            <div class=\"label\">CORE TEMPERATURE</div>\n            <input type=\"range\" id=\"temp-slider\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0\">\n            <div class=\"label\" style=\"display:flex; justify-content:space-between;\">\n                <span>FROZEN</span><span>MELTDOWN</span>\n            </div>\n            <br>\n            <button id=\"glitch-btn\">TRIGGER INSTABILITY</button>\n        </div>\n\n        <div class=\"hud-element bottom-right\">\n            <div class=\"label\">ENERGY OUTPUT</div>\n            <div class=\"metric\" id=\"energy-metric\">100%</div>\n            <div class=\"label\">PARTICLE COUNT</div>\n            <div class=\"metric\">2,200</div>\n        </div>\n    </div>\n\n    <script>\n        function logStatus(msg) {\n            const el = document.getElementById('status-log');\n            if(el) el.innerText = msg;\n            console.log(msg);\n        }\n        function logError(err) {\n            const el = document.getElementById('error-msg');\n            const status = document.getElementById('status-log');\n            if(status) status.style.color = 'red';\n            if(status) status.innerText = \"SYSTEM FAILURE\";\n            if(el) el.innerHTML += `<div>${err}</div>`;\n        }\n        window.onerror = function(msg, url, line) {\n            logError(`Error: ${msg} <br> Line: ${line}`);\n        };\n    </script>\n\n    <script type=\"module\">\n        import * as THREE from 'three';\n        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';\n        import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';\n        import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';\n        import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';\n        import { GlitchPass } from 'three/addons/postprocessing/GlitchPass.js';\n        import * as CANNON from 'cannon-es';\n\n        logStatus(\"LIBRARIES LOADED. STARTING ENGINE...\");\n\n        let scene, camera, renderer, composer, controls;\n        let world, physicsSnow = [], visualSnow;\n        let iceCoreMesh, iceCoreBody;\n        let glitchPass;\n        let meltFactor = 0;\n        \n        const mouse = new THREE.Vector2();\n        const raycaster = new THREE.Raycaster();\n        const plane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0); \n        const mouse3D = new THREE.Vector3(); \n\n        try {\n            init();\n        } catch(e) {\n            logError(e.message);\n        }\n\n        function init() {\n            logStatus(\"BUILDING 3D ENVIRONMENT...\");\n\n            // SETUP THREE.JS\n            const container = document.getElementById('canvas-container');\n            scene = new THREE.Scene();\n            scene.fog = new THREE.FogExp2(0x000510, 0.02);\n\n            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);\n            camera.position.set(0, 2, 12);\n\n            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n            renderer.setSize(window.innerWidth, window.innerHeight);\n            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n            renderer.toneMapping = THREE.ReinhardToneMapping;\n            container.appendChild(renderer.domElement);\n\n            // SETUP PHYSICS WORLD\n            logStatus(\"INITIALIZING PHYSICS ENGINE...\");\n            world = new CANNON.World();\n            world.gravity.set(0, -1.0, 0); \n            \n            // LIGHTING\n            const ambient = new THREE.AmbientLight(0x404040, 2);\n            scene.add(ambient);\n            const pLight = new THREE.PointLight(0x00ffff, 3, 50);\n            scene.add(pLight);\n            const rimLight = new THREE.DirectionalLight(0xffffff, 4);\n            rimLight.position.set(5, 5, 5);\n            scene.add(rimLight);\n\n            // CREATE OBJECTS\n            createIceCore();\n            createPhysicsSnow(200); \n            createVisualSnow(2000); \n\n            // POST PROCESSING\n            composer = new EffectComposer(renderer);\n            composer.addPass(new RenderPass(scene, camera));\n            \n            const bloom = new UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 1.5, 0.4, 0.85);\n            composer.addPass(bloom);\n\n            glitchPass = new GlitchPass();\n            glitchPass.enabled = false; \n            composer.addPass(glitchPass);\n\n            // CONTROLS\n            controls = new OrbitControls(camera, renderer.domElement);\n            controls.enableDamping = true;\n            controls.autoRotate = true;\n            controls.autoRotateSpeed = 0.5;\n\n            window.addEventListener('resize', onWindowResize);\n            window.addEventListener('mousemove', onMouseMove);\n            \n            document.getElementById('temp-slider').addEventListener('input', (e) => {\n                meltFactor = parseFloat(e.target.value);\n            });\n\n            document.getElementById('glitch-btn').addEventListener('click', () => {\n                glitchPass.enabled = true;\n                setTimeout(() => { glitchPass.enabled = false; }, 1000);\n            });\n\n            // SUCCESS\n            logStatus(\"SYSTEM READY.\");\n            setTimeout(() => {\n                document.getElementById('debug-screen').style.display = 'none';\n            }, 500);\n\n            animate();\n        }\n\n        // CORE \n        function createIceCore() {\n            // Physics\n            const shape = new CANNON.Sphere(2); \n            iceCoreBody = new CANNON.Body({ mass: 0, material: new CANNON.Material({ friction: 0.1, restitution: 0.5 }) });\n            iceCoreBody.addShape(shape);\n            world.addBody(iceCoreBody);\n\n            // Visual\n            const geometry = new THREE.IcosahedronGeometry(2, 30); \n            \n            const material = new THREE.ShaderMaterial({\n                uniforms: {\n                    time: { value: 0 },\n                    color: { value: new THREE.Color('#00ffff') },\n                    meltFactor: { value: 0 },\n                    cameraPos: { value: camera.position }\n                },\n                vertexShader: `\n                    varying vec3 vNormal; varying vec3 vPosition;\n                    uniform float time; uniform float meltFactor;\n                    \n                    float hash(float n) { return fract(sin(n) * 1e4); }\n                    float noise(vec3 x) {\n                        const vec3 step = vec3(110, 241, 171);\n                        vec3 i = floor(x); vec3 f = fract(x);\n                        float n = dot(i, step);\n                        vec3 u = f * f * (3.0 - 2.0 * f);\n                        return mix(mix(mix( hash(n + dot(step, vec3(0, 0, 0))), hash(n + dot(step, vec3(1, 0, 0))), u.x),\n                                   mix( hash(n + dot(step, vec3(0, 1, 0))), hash(n + dot(step, vec3(1, 1, 0))), u.x), u.y),\n                                   mix(mix( hash(n + dot(step, vec3(0, 0, 1))), hash(n + dot(step, vec3(1, 0, 1))), u.x),\n                                   mix( hash(n + dot(step, vec3(0, 1, 1))), hash(n + dot(step, vec3(1, 1, 1))), u.x), u.y), u.z);\n                    }\n\n                    void main() {\n                        vNormal = normalize(normalMatrix * normal);\n                        float spikes = sin(time * 2.0 + position.y * 4.0) * 0.1;\n                        spikes += noise(position * 3.0 + time) * 0.2;\n                        float heartbeat = (sin(time * 3.0) * 0.5 + 0.5) * 0.15;\n                        float pulse = heartbeat * noise(position * 2.0);\n                        float water = sin(time * 3.0 + position.x * 2.0) * 0.05;\n                        float finalDisp = mix(spikes + pulse, water, meltFactor);\n                        vec3 newPos = position + normal * finalDisp;\n                        vPosition = (modelMatrix * vec4(newPos, 1.0)).xyz;\n                        gl_Position = projectionMatrix * modelViewMatrix * vec4(newPos, 1.0);\n                    }\n                `,\n                fragmentShader: `\n                    varying vec3 vNormal; varying vec3 vPosition;\n                    uniform vec3 color; uniform vec3 cameraPos; uniform float meltFactor;\n                    void main() {\n                        vec3 viewDir = normalize(cameraPos - vPosition);\n                        vec3 normal = normalize(vNormal);\n                        float fresnel = pow(1.0 - dot(viewDir, normal), 3.0);\n                        vec3 iceColor = color * 0.5;\n                        vec3 waterColor = vec3(0.0, 0.2, 0.5);\n                        vec3 edgeColor = vec3(1.0);\n                        vec3 base = mix(iceColor, waterColor, meltFactor);\n                        vec3 finalColor = mix(base, edgeColor, fresnel * (1.0 - meltFactor * 0.5));\n                        gl_FragColor = vec4(finalColor, 0.7 + fresnel * 0.3); \n                    }\n                `,\n                transparent: true,\n                side: THREE.DoubleSide\n            });\n\n            iceCoreMesh = new THREE.Mesh(geometry, material);\n            scene.add(iceCoreMesh);\n        }\n\n        function createPhysicsSnow(count) {\n            const geo = new THREE.SphereGeometry(0.1, 4, 4);\n            const mat = new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0x555555 });\n            \n            for(let i=0; i<count; i++) {\n                const body = new CANNON.Body({\n                    mass: 0.1,\n                    shape: new CANNON.Sphere(0.1),\n                    linearDamping: 0.1\n                });\n                resetParticle(body);\n                world.addBody(body);\n                const mesh = new THREE.Mesh(geo, mat);\n                scene.add(mesh);\n                physicsSnow.push({ mesh, body });\n            }\n        }\n\n        function resetParticle(body) {\n            const x = (Math.random() - 0.5) * 10;\n            const z = (Math.random() - 0.5) * 10;\n            body.position.set(x, 10 + Math.random() * 5, z);\n            body.velocity.set(0,0,0);\n        }\n\n        function createVisualSnow(count) {\n            const geo = new THREE.BufferGeometry();\n            const pos = [];\n            for(let i=0; i<count; i++) {\n                pos.push((Math.random()-0.5)*30, (Math.random()-0.5)*30, (Math.random()-0.5)*30);\n            }\n            geo.setAttribute('position', new THREE.Float32BufferAttribute(pos, 3));\n            \n            const mat = new THREE.PointsMaterial({\n                color: 0x88ccff, size: 0.1, transparent: true, opacity: 0.6,\n                blending: THREE.AdditiveBlending\n            });\n            \n            visualSnow = new THREE.Points(geo, mat);\n            scene.add(visualSnow);\n        }\n\n        function onMouseMove(event) {\n            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;\n            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;\n            raycaster.setFromCamera(mouse, camera);\n            raycaster.ray.intersectPlane(plane, mouse3D);\n        }\n\n        function onWindowResize() {\n            camera.aspect = window.innerWidth / window.innerHeight;\n            camera.updateProjectionMatrix();\n            renderer.setSize(window.innerWidth, window.innerHeight);\n            composer.setSize(window.innerWidth, window.innerHeight);\n        }\n\n        const clock = new THREE.Clock();\n\n        function animate() {\n            requestAnimationFrame(animate);\n            const delta = clock.getDelta();\n            const time = clock.getElapsedTime();\n\n            world.step(1/60, delta, 3);\n\n            iceCoreMesh.rotation.y = time * 0.1;\n            iceCoreMesh.material.uniforms.time.value = time;\n            iceCoreMesh.material.uniforms.cameraPos.value = camera.position;\n            iceCoreMesh.material.uniforms.meltFactor.value = meltFactor;\n\n            physicsSnow.forEach(p => {\n                p.mesh.position.copy(p.body.position);\n                p.mesh.quaternion.copy(p.body.quaternion);\n                if(p.body.position.y < -10) resetParticle(p.body);\n                const dist = p.body.position.distanceTo(mouse3D);\n                if (dist < 4) {\n                    const force = new CANNON.Vec3(p.body.position.x - mouse3D.x, p.body.position.y - mouse3D.y, p.body.position.z - mouse3D.z);\n                    force.normalize(); force.scale(8, force);\n                    p.body.applyForce(force, p.body.position);\n                }\n                p.body.applyForce(new CANNON.Vec3(Math.cos(time + p.body.position.y)*0.5, 0, Math.sin(time)*0.5), p.body.position);\n            });\n\n            const positions = visualSnow.geometry.attributes.position.array;\n            for(let i=0; i<positions.length; i+=3) {\n                positions[i+1] -= 0.05; \n                if(positions[i+1] < -15) positions[i+1] = 15;\n                positions[i] += Math.cos(time + positions[i+1]) * 0.02;\n            }\n            visualSnow.geometry.attributes.position.needsUpdate = true;\n\n            controls.update();\n            composer.render();\n        }\n    </script>\n</body>\n</html>\n    \n  </body>\n  \n</html>\n"}