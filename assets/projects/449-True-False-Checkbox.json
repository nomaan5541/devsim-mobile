{"index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>True False</title>\n    \n\n  </head>\n    \n  <body>\n  <style>\n\tbody {\n\t\tmargin: 0;\n\t\tpadding: 0;\n\t\theight: 100vh;\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\talign-items: center;\n\t\tbackground-color: #111;\n\t\tcolor: #fff;\n\t\tfont-family: Arial, sans-serif;\n\t}\n\n\tdiv {\n\t\tposition: relative;\n\t\tdisplay: flex;\n\t\tflex-wrap: wrap;\n\t\twidth: 660px;\n\t\theight: 660px;\n\t}\n\n\tinput {\n\t\tposition: absolute;\n\t\twidth: 30px;\n\t\theight: 30px;\n\t\tmargin: 5px;\n\t\tcursor: pointer;\n\t\tborder: 2px solid #fff;\n\t\tborder-radius: 50%;\n\t\tbackground-color: transparent;\n\t\ttransition: transform 0.3s ease;\n\t\tbox-shadow: 0 0 10px rgba(255, 255, 255, 0.7), 0 0 15px rgba(255, 255, 255, 0.7), 0 0 30px rgba(255, 255, 255, 0.7);\n\t}\n\n\tinput:checked {\n\t\tbackground-color: #39ff14;\n\t\t/* Neon green */\n\t\tbox-shadow: 0 0 20px #39ff14, 0 0 30px #39ff14, 0 0 50px #39ff14;\n\t}\n\n\tinput.grow {\n\t\tanimation: grow 0.8s ease-out forwards;\n\t}\n\n\t@keyframes grow {\n\t\t0% {\n\t\t\ttransform: scale(1);\n\t\t}\n\n\t\t20% {\n\t\t\ttransform: scale(1.5);\n\t\t}\n\n\t\t100% {\n\t\t\ttransform: scale(1);\n\t\t}\n\t}\n\n\t@keyframes pulse {\n\t\t0% {\n\t\t\ttransform: scale(1);\n\t\t}\n\n\t\t50% {\n\t\t\ttransform: scale(1.8);\n\t\t}\n\n\t\t100% {\n\t\t\ttransform: scale(1);\n\t\t}\n\t}\n\n\t.pulse {\n\t\tanimation: pulse 1s ease-in-out forwards;\n\t}\n</style>\n\n<div id=\"wrapper\"></div>\n\n<script>\n\tconst RES_X = 10;\n\tconst RES_Y = 10;\n\tconst SIZE = 60;\n\tconst entities = [];\n\tconst wrapper = document.getElementById('wrapper');\n\twrapper.style.width = `${RES_X * SIZE}px`;\n\twrapper.style.height = `${RES_Y * SIZE}px`;\n\tfor (let x = 0; x < RES_X; x++) {\n\t\tfor (let y = 0; y < RES_Y; y++) {\n\t\t\tconst el = document.createElement('input');\n\t\t\tel.setAttribute('type', 'checkbox');\n\t\t\twrapper.appendChild(el);\n\t\t\tconst entity = {\n\t\t\t\telement: el,\n\t\t\t\tx: x * SIZE,\n\t\t\t\ty: y * SIZE,\n\t\t\t};\n\t\t\tel.style.left = `${entity.x}px`;\n\t\t\tel.style.top = `${entity.y}px`;\n\t\t\tel.addEventListener('change', () => toggle(entity));\n\t\t\tentities.push(entity);\n\t\t}\n\t}\n\n\tfunction toggle(targetEntity) {\n\t\tconst checked = targetEntity.element.checked;\n\t\tentities.forEach(entity => {\n\t\t\tconst dx = targetEntity.x - entity.x;\n\t\t\tconst dy = targetEntity.y - entity.y;\n\t\t\tconst distance = Math.sqrt(dx * dx + dy * dy);\n\t\t\tsetTimeout(() => {\n\t\t\t\tentity.element.checked = checked;\n\t\t\t\t// Add pulse effect on toggle\n\t\t\t\tif (checked) {\n\t\t\t\t\tentity.element.classList.add('pulse');\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tentity.element.classList.remove('pulse');\n\t\t\t\t\t}, 1000);\n\t\t\t\t}\n\t\t\t\t// Trigger grow animation\n\t\t\t\tentity.element.classList.add('grow');\n\t\t\t\tentity.element.offsetWidth; // force reflow\n\t\t\t\tentity.element.classList.remove('grow');\n\t\t\t}, Math.round(distance * 1.8));\n\t\t});\n\t}\n\tsetTimeout(() => {\n\t\tentities[0].element.checked = true;\n\t\ttoggle(entities[0]);\n\t}, 500);\n</script>\n    \n  </body>\n  \n</html>\n"}