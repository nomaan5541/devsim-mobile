{"index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Crossroad \u2014 Opposite Directions</title>\n    \n\n  </head>\n    \n  <body>\n  <!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Crossroad \u2014 Opposite Directions</title>\n<style>\n/* \u2500\u2500 Variables \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n:root {\n  --road-w: 160px;\n  --asphalt: #16213e;\n  --lane-dash: #f0c040;\n  --white-line: #e8e8e0;\n  --grass: #0d1f0f;\n  --b1: #0f3460;\n  --b2: #162447;\n  --b3: #1b1b2f;\n}\n\n/* \u2500\u2500 Reset \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  background: #06060f;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-height: 100vh;\n  font-family: 'Courier New', monospace;\n  overflow: hidden;\n}\n\n.page-title {\n  color: #ffffff1a;\n  font-size: 11px;\n  letter-spacing: 0.35em;\n  text-transform: uppercase;\n  position: fixed;\n  top: 18px;\n  left: 50%;\n  transform: translateX(-50%);\n  z-index: 100;\n  white-space: nowrap;\n}\n\n/* \u2500\u2500 Scene \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.scene {\n  position: relative;\n  width: 600px;\n  height: 600px;\n  overflow: hidden;\n  border-radius: 4px;\n}\n\n/* \u2500\u2500 City Quadrants \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.quad {\n  position: absolute;\n  background: var(--grass);\n  overflow: hidden;\n}\n.quad::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background:\n    radial-gradient(circle at 30% 70%, #1a3a1a, transparent 60%),\n    radial-gradient(circle at 80% 20%, #122a12, transparent 50%);\n}\n.quad-tl { top:0;    left:0;   width:calc(50% - var(--road-w)/2); height:calc(50% - var(--road-w)/2); }\n.quad-tr { top:0;    right:0;  width:calc(50% - var(--road-w)/2); height:calc(50% - var(--road-w)/2); }\n.quad-bl { bottom:0; left:0;   width:calc(50% - var(--road-w)/2); height:calc(50% - var(--road-w)/2); }\n.quad-br { bottom:0; right:0;  width:calc(50% - var(--road-w)/2); height:calc(50% - var(--road-w)/2); }\n\n/* \u2500\u2500 Buildings \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.building {\n  position: absolute;\n  border-radius: 2px;\n  box-shadow: 0 0 12px #00aaff11;\n}\n.building::before {\n  content: '';\n  position: absolute;\n  inset: 4px;\n  background:\n    repeating-linear-gradient(0deg,  transparent 0, transparent 6px, #fff1 6px, #fff1 7px),\n    repeating-linear-gradient(90deg, transparent 0, transparent 8px, #fff1 8px, #fff1 9px);\n}\n.building::after {\n  content: '';\n  position: absolute;\n  inset: 4px;\n  background:\n    radial-gradient(circle at 20% 30%, #ffcc0033 0, transparent 8px),\n    radial-gradient(circle at 70% 20%, #ffcc0055 0, transparent 6px),\n    radial-gradient(circle at 40% 70%, #ffcc0044 0, transparent 7px),\n    radial-gradient(circle at 80% 60%, #00aaff33 0, transparent 6px);\n  animation: winBlink 3.5s ease-in-out infinite alternate;\n}\n@keyframes winBlink { 0%,100%{opacity:1} 50%{opacity:.35} }\n\n.quad-tl .b1{background:var(--b1);bottom:10px;right:14px;width:65px;height:90px}\n.quad-tl .b2{background:var(--b2);bottom:14px;left:10px;width:45px;height:65px}\n.quad-tl .b3{background:var(--b3);top:10px;right:8px;width:38px;height:50px}\n.quad-tr .b1{background:var(--b2);bottom:10px;left:14px;width:60px;height:80px}\n.quad-tr .b2{background:var(--b1);top:12px;left:10px;width:42px;height:55px}\n.quad-tr .b3{background:var(--b3);bottom:12px;right:10px;width:35px;height:48px}\n.quad-bl .b1{background:var(--b3);top:10px;right:14px;width:58px;height:75px}\n.quad-bl .b2{background:var(--b1);top:14px;left:8px;width:44px;height:60px}\n.quad-bl .b3{background:var(--b2);bottom:10px;right:8px;width:36px;height:46px}\n.quad-br .b1{background:var(--b1);top:10px;left:14px;width:62px;height:82px}\n.quad-br .b2{background:var(--b2);top:12px;right:10px;width:40px;height:58px}\n.quad-br .b3{background:var(--b3);bottom:10px;left:10px;width:38px;height:50px}\n\n/* \u2500\u2500 Roads \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.road-h,.road-v{position:absolute;background:var(--asphalt)}\n.road-h{top:50%;left:0;width:100%;height:var(--road-w);transform:translateY(-50%)}\n.road-v{left:50%;top:0;height:100%;width:var(--road-w);transform:translateX(-50%)}\n.road-h::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(180deg,#0005,transparent)}\n.road-h::after {content:'';position:absolute;bottom:0;left:0;right:0;height:6px;background:linear-gradient(0deg,#0005,transparent)}\n.road-v::before{content:'';position:absolute;left:0;top:0;bottom:0;width:6px;background:linear-gradient(90deg,#0005,transparent)}\n.road-v::after {content:'';position:absolute;right:0;top:0;bottom:0;width:6px;background:linear-gradient(270deg,#0005,transparent)}\n\n.intersection{\n  position:absolute;top:50%;left:50%;\n  width:var(--road-w);height:var(--road-w);\n  transform:translate(-50%,-50%);\n  background:#1c1c32;z-index:5\n}\n\n/* \u2500\u2500 Lane Markings \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.lm{\n  position:absolute;\n  background:repeating-linear-gradient(\n    var(--lm-dir,90deg),\n    var(--lane-dash) 0,var(--lane-dash) 18px,\n    transparent 18px,transparent 32px\n  );\n  z-index:6;\n  animation:var(--lm-anim,dashH) 1.2s linear infinite;\n}\n.lm-hl{--lm-dir:90deg;--lm-anim:dashH;top:50%;height:2px;transform:translateY(-50%);left:0;width:calc(50% - var(--road-w)/2)}\n.lm-hr{--lm-dir:90deg;--lm-anim:dashH;top:50%;height:2px;transform:translateY(-50%);left:calc(50% + var(--road-w)/2);width:calc(50% - var(--road-w)/2)}\n.lm-vt{--lm-dir:180deg;--lm-anim:dashV;left:50%;width:2px;transform:translateX(-50%);top:0;height:calc(50% - var(--road-w)/2)}\n.lm-vb{--lm-dir:180deg;--lm-anim:dashV;left:50%;width:2px;transform:translateX(-50%);top:calc(50% + var(--road-w)/2);height:calc(50% - var(--road-w)/2)}\n@keyframes dashH{from{background-position:0 0}to{background-position:50px 0}}\n@keyframes dashV{from{background-position:0 0}to{background-position:0 50px}}\n\n/* \u2500\u2500 Zebra Crossings \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.zebra{position:absolute;z-index:7;opacity:.55}\n.zebra-top   {top:calc(50% - var(--road-w)/2 - 18px);left:calc(50% - var(--road-w)/2);width:var(--road-w);height:18px;background:repeating-linear-gradient(90deg,var(--white-line) 0,var(--white-line) 9px,transparent 9px,transparent 18px)}\n.zebra-bottom{bottom:calc(50% - var(--road-w)/2 - 18px);left:calc(50% - var(--road-w)/2);width:var(--road-w);height:18px;background:repeating-linear-gradient(90deg,var(--white-line) 0,var(--white-line) 9px,transparent 9px,transparent 18px)}\n.zebra-left  {left:calc(50% - var(--road-w)/2 - 18px);top:calc(50% - var(--road-w)/2);width:18px;height:var(--road-w);background:repeating-linear-gradient(180deg,var(--white-line) 0,var(--white-line) 9px,transparent 9px,transparent 18px)}\n.zebra-right {right:calc(50% - var(--road-w)/2 - 18px);top:calc(50% - var(--road-w)/2);width:18px;height:var(--road-w);background:repeating-linear-gradient(180deg,var(--white-line) 0,var(--white-line) 9px,transparent 9px,transparent 18px)}\n\n/* \u2500\u2500 Traffic Lights (JS-driven) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.tl-wrap{position:absolute;z-index:20}\n.tl-ne{top:calc(50% - var(--road-w)/2 - 30px);right:calc(50% - var(--road-w)/2 - 28px)}\n.tl-sw{bottom:calc(50% - var(--road-w)/2 - 30px);left:calc(50% - var(--road-w)/2 - 28px)}\n.tl-nw{top:calc(50% - var(--road-w)/2 - 30px);left:calc(50% - var(--road-w)/2 - 28px)}\n.tl-se{bottom:calc(50% - var(--road-w)/2 - 30px);right:calc(50% - var(--road-w)/2 - 28px)}\n\n.tl-box{\n  width:14px;background:#0e0e0e;border-radius:7px;\n  padding:3px;display:flex;flex-direction:column;gap:3px;\n  box-shadow:0 0 6px #000a,inset 0 0 3px #fff1\n}\n.tl-dot{\n  width:8px;height:8px;border-radius:50%;\n  background:#1a1a1a;\n  transition:background .25s,box-shadow .25s\n}\n.tl-dot.on-red  {background:#ff3355;box-shadow:0 0 8px #ff3355,0 0 18px #ff335555}\n.tl-dot.on-amber{background:#ffaa00;box-shadow:0 0 8px #ffaa00,0 0 18px #ffaa0055}\n.tl-dot.on-green{background:#00ff88;box-shadow:0 0 8px #00ff88,0 0 18px #00ff8855}\n\n/* \u2500\u2500 Cars \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n/* All positioned entirely by JS via transform:translate(x,y)  */\n.car{\n  position:absolute;top:0;left:0;\n  border-radius:3px;z-index:15;\n  filter:drop-shadow(0 3px 8px #000c);\n  will-change:transform\n}\n.car-lr,.car-rl{width:36px;height:22px}\n.car-tb,.car-bt{width:22px;height:36px}\n\n/* Car body colours */\n#carA1{background:linear-gradient(180deg,#e63950,#991a2c)}\n#carA2{background:linear-gradient(180deg,#e68c39,#995015)}\n#carB1{background:linear-gradient(180deg,#39a0e6,#155499)}\n#carB2{background:linear-gradient(180deg,#a439e6,#5a1599)}\n#carC1{background:linear-gradient(90deg,#39e67a,#158840)}\n#carC2{background:linear-gradient(90deg,#e6d639,#998a15)}\n#carD1{background:linear-gradient(90deg,#e63982,#991545)}\n#carD2{background:linear-gradient(90deg,#39e6e6,#159999)}\n\n/* \u2500\u2500 TWO Headlights \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.hl{\n  position:absolute;\n  width:5px;height:5px;border-radius:50%;\n  background:#fffde8;\n  box-shadow:0 0 7px 3px #fffde8aa,0 0 14px 5px #ffffff44;\n  z-index:2\n}\n/* LR \u2192 front = right edge */\n.car-lr .hl-a{right:2px;top:3px}\n.car-lr .hl-b{right:2px;bottom:3px}\n/* RL \u2192 front = left edge */\n.car-rl .hl-a{left:2px;top:3px}\n.car-rl .hl-b{left:2px;bottom:3px}\n/* TB \u2192 front = bottom edge */\n.car-tb .hl-a{bottom:2px;left:3px}\n.car-tb .hl-b{bottom:2px;right:3px}\n/* BT \u2192 front = top edge */\n.car-bt .hl-a{top:2px;left:3px}\n.car-bt .hl-b{top:2px;right:3px}\n\n/* \u2500\u2500 Tail-lights \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.tail{\n  position:absolute;\n  width:4px;height:5px;border-radius:1px;\n  background:#ff3355;\n  box-shadow:0 0 5px #ff335577;\n  z-index:2;\n  transition:box-shadow .12s,background .12s\n}\n/* Braking \u2192 vivid red glow */\n.car.braking .tail{\n  background:#ff0033;\n  box-shadow:0 0 10px 3px #ff0033cc\n}\n/* LR: tails on left */\n.car-lr .tail-a{left:2px;top:3px}\n.car-lr .tail-b{left:2px;bottom:3px}\n/* RL: tails on right */\n.car-rl .tail-a{right:2px;top:3px}\n.car-rl .tail-b{right:2px;bottom:3px}\n/* TB: tails on top */\n.car-tb .tail-a{top:2px;left:3px}\n.car-tb .tail-b{top:2px;right:3px}\n/* BT: tails on bottom */\n.car-bt .tail-a{bottom:2px;left:3px}\n.car-bt .tail-b{bottom:2px;right:3px}\n\n/* \u2500\u2500 Headlight Cone \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.cone{position:absolute;pointer-events:none;z-index:1;opacity:.45}\n.car-lr .cone{right:-30px;top:0;width:32px;height:22px;background:linear-gradient(90deg,#fffde0,transparent);clip-path:polygon(0 18%,100% 0%,100% 100%,0 82%)}\n.car-rl .cone{left:-30px;top:0;width:32px;height:22px;background:linear-gradient(270deg,#fffde0,transparent);clip-path:polygon(100% 18%,0% 0%,0% 100%,100% 82%)}\n.car-tb .cone{bottom:-30px;left:0;width:22px;height:32px;background:linear-gradient(180deg,#fffde0,transparent);clip-path:polygon(18% 0%,82% 0%,100% 100%,0% 100%)}\n.car-bt .cone{top:-30px;left:0;width:22px;height:32px;background:linear-gradient(0deg,#fffde0,transparent);clip-path:polygon(0% 0%,100% 0%,82% 100%,18% 100%)}\n\n/* \u2500\u2500 Street Lamps \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.lamp{position:absolute;width:4px;height:20px;background:#444;border-radius:2px 2px 0 0;z-index:18}\n.lamp::before{\n  content:'';position:absolute;top:-3px;left:50%;transform:translateX(-50%);\n  width:10px;height:10px;border-radius:50%;\n  background:radial-gradient(circle,#fff8c0 20%,#ffdd0066 60%,transparent 80%);\n  box-shadow:0 0 20px 8px #ffdd0033,0 0 40px 16px #ffdd0011;\n  animation:lampFlicker 5s ease-in-out infinite\n}\n@keyframes lampFlicker{0%,95%,100%{opacity:1}96%{opacity:.7}97%{opacity:1}98%{opacity:.5}99%{opacity:1}}\n.lamp-1{top:calc(50% - var(--road-w)/2 - 22px);left:calc(50% - var(--road-w)/2 - 6px)}\n.lamp-2{top:calc(50% - var(--road-w)/2 - 22px);left:calc(50% + var(--road-w)/2 + 2px)}\n.lamp-3{top:calc(50% + var(--road-w)/2 + 2px); left:calc(50% - var(--road-w)/2 - 6px)}\n.lamp-4{top:calc(50% + var(--road-w)/2 + 2px); left:calc(50% + var(--road-w)/2 + 2px)}\n\n/* \u2500\u2500 Atmosphere & Stars \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.atmosphere{position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 40%,#06060f99 100%);pointer-events:none;z-index:25}\n.stars{\n  position:fixed;inset:0;z-index:0;pointer-events:none;\n  background-image:\n    radial-gradient(circle,#fff 1px,transparent 1px),\n    radial-gradient(circle,#fff 1px,transparent 1px),\n    radial-gradient(circle,#fff8 1px,transparent 1px);\n  background-size:200px 200px,350px 350px,150px 150px;\n  background-position:40px 30px,100px 80px,20px 160px;\n  opacity:.22\n}\n\n/* \u2500\u2500 Legend \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.legend{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);display:flex;gap:20px;z-index:100}\n.legend-item{display:flex;align-items:center;gap:6px;font-size:9px;color:#ffffff44;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap}\n.legend-dot{width:8px;height:8px;border-radius:1px;flex-shrink:0}\n</style>\n</head>\n<body>\n\n<div class=\"stars\"></div>\n<div class=\"page-title\">Crossroad &mdash; Opposite Directions</div>\n\n<div class=\"scene\">\n\n  <!-- Quadrant city blocks -->\n  <div class=\"quad quad-tl\"><div class=\"building b1\"></div><div class=\"building b2\"></div><div class=\"building b3\"></div></div>\n  <div class=\"quad quad-tr\"><div class=\"building b1\"></div><div class=\"building b2\"></div><div class=\"building b3\"></div></div>\n  <div class=\"quad quad-bl\"><div class=\"building b1\"></div><div class=\"building b2\"></div><div class=\"building b3\"></div></div>\n  <div class=\"quad quad-br\"><div class=\"building b1\"></div><div class=\"building b2\"></div><div class=\"building b3\"></div></div>\n\n  <!-- Roads -->\n  <div class=\"road-h\"></div>\n  <div class=\"road-v\"></div>\n  <div class=\"intersection\"></div>\n\n  <!-- Lane markings -->\n  <div class=\"lm lm-hl\"></div>\n  <div class=\"lm lm-hr\"></div>\n  <div class=\"lm lm-vt\"></div>\n  <div class=\"lm lm-vb\"></div>\n\n  <!-- Zebra crossings -->\n  <div class=\"zebra zebra-top\"></div>\n  <div class=\"zebra zebra-bottom\"></div>\n  <div class=\"zebra zebra-left\"></div>\n  <div class=\"zebra zebra-right\"></div>\n\n  <!--\n    Traffic lights\n    NE + SW = NS axis  \u2192  governs TB (top\u2192bottom) and BT (bottom\u2192top) cars\n    NW + SE = EW axis  \u2192  governs LR (left\u2192right) and RL (right\u2192left) cars\n  -->\n  <div class=\"tl-wrap tl-ne\" id=\"tl-ne\">\n    <div class=\"tl-box\">\n      <div class=\"tl-dot\" data-c=\"red\"></div>\n      <div class=\"tl-dot\" data-c=\"amber\"></div>\n      <div class=\"tl-dot\" data-c=\"green\"></div>\n    </div>\n  </div>\n  <div class=\"tl-wrap tl-sw\" id=\"tl-sw\">\n    <div class=\"tl-box\">\n      <div class=\"tl-dot\" data-c=\"red\"></div>\n      <div class=\"tl-dot\" data-c=\"amber\"></div>\n      <div class=\"tl-dot\" data-c=\"green\"></div>\n    </div>\n  </div>\n  <div class=\"tl-wrap tl-nw\" id=\"tl-nw\">\n    <div class=\"tl-box\">\n      <div class=\"tl-dot\" data-c=\"red\"></div>\n      <div class=\"tl-dot\" data-c=\"amber\"></div>\n      <div class=\"tl-dot\" data-c=\"green\"></div>\n    </div>\n  </div>\n  <div class=\"tl-wrap tl-se\" id=\"tl-se\">\n    <div class=\"tl-box\">\n      <div class=\"tl-dot\" data-c=\"red\"></div>\n      <div class=\"tl-dot\" data-c=\"amber\"></div>\n      <div class=\"tl-dot\" data-c=\"green\"></div>\n    </div>\n  </div>\n\n  <!-- Street lamps -->\n  <div class=\"lamp lamp-1\"></div>\n  <div class=\"lamp lamp-2\"></div>\n  <div class=\"lamp lamp-3\"></div>\n  <div class=\"lamp lamp-4\"></div>\n\n  <!--\n    CARS\n    Each car contains:\n      .cone     \u2013 headlight beam in travel direction\n      .hl-a/b   \u2013 TWO headlights on the front face\n      .tail-a/b \u2013 TWO tail-lights on the rear face\n    JS sets transform:translate(x,y) every frame.\n  -->\n\n  <!-- Left \u2192 Right  (EW axis) -->\n  <div class=\"car car-lr\" id=\"carA1\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n  <div class=\"car car-lr\" id=\"carA2\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n\n  <!-- Right \u2192 Left  (EW axis) -->\n  <div class=\"car car-rl\" id=\"carB1\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n  <div class=\"car car-rl\" id=\"carB2\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n\n  <!-- Top \u2192 Bottom  (NS axis) -->\n  <div class=\"car car-tb\" id=\"carC1\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n  <div class=\"car car-tb\" id=\"carC2\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n\n  <!-- Bottom \u2192 Top  (NS axis) -->\n  <div class=\"car car-bt\" id=\"carD1\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n  <div class=\"car car-bt\" id=\"carD2\">\n    <div class=\"cone\"></div>\n    <div class=\"hl hl-a\"></div><div class=\"hl hl-b\"></div>\n    <div class=\"tail tail-a\"></div><div class=\"tail tail-b\"></div>\n  </div>\n\n  <div class=\"atmosphere\"></div>\n</div>\n\n<div class=\"legend\">\n  <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#e63950\"></div>L &rarr; R</div>\n  <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#39a0e6\"></div>R &rarr; L</div>\n  <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#39e67a\"></div>T &rarr; B</div>\n  <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#e63982\"></div>B &rarr; T</div>\n</div>\n\n<script>\n'use strict';\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   GEOMETRY\n   Scene 600\u00d7600 px \u00b7 Road width 160 px\n   Intersection occupies x[220..380] \u00d7 y[220..380]\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\nconst SW = 600, SH = 600;\nconst RW = 160;\nconst IL = (SW - RW) / 2;   // 220  intersection left\nconst IR = (SW + RW) / 2;   // 380  intersection right\nconst IT = (SH - RW) / 2;   // 220  intersection top\nconst IB = (SH + RW) / 2;   // 380  intersection bottom\n\nconst CW = 36, CH = 22;     // horizontal car W\u00d7H\nconst VW = 22, VH = 36;     // vertical   car W\u00d7H\n\n// Pixels between car front and intersection edge when waiting\nconst PAD = 5;\n\n// Stop positions \u2014 car's top-left corner when held at red\nconst SX_LR = IL - CW - PAD;  // 179   LR car waits here\nconst SX_RL = IR + PAD;        // 385   RL car waits here\nconst SY_TB = IT - VH - PAD;  // 179   TB car waits here\nconst SY_BT = IB + PAD;        // 385   BT car waits here\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   TRAFFIC LIGHT STATE MACHINE\n   \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n   Axes:\n     NS (NE + SW boxes) \u2192 governs TB and BT cars\n     EW (NW + SE boxes) \u2192 governs LR and RL cars\n\n   9-second cycle:\n     0 ms \u2026 4000   NS green  /  EW red\n     4000  \u2026 4500  NS amber  /  EW red      \u2190 NS clearing\n     4500  \u2026 8500  NS red    /  EW green\n     8500  \u2026 9000  NS red    /  EW amber     \u2190 EW clearing\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\nconst CYCLE  = 9000;\nconst PHASES = [\n  { t:    0, ns: 'green', ew: 'red'   },\n  { t: 4000, ns: 'amber', ew: 'red'   },\n  { t: 4500, ns: 'red',   ew: 'green' },\n  { t: 8500, ns: 'red',   ew: 'amber' },\n];\n\nlet nsState      = '';\nlet ewState      = '';\nlet lastPhaseIdx = -1;\n\nconst tlGroups = {\n  ns: [document.getElementById('tl-ne'), document.getElementById('tl-sw')],\n  ew: [document.getElementById('tl-nw'), document.getElementById('tl-se')],\n};\n\nfunction lightBox(boxEl, color) {\n  boxEl.querySelectorAll('.tl-dot').forEach(dot => {\n    dot.classList.remove('on-red', 'on-amber', 'on-green');\n    if (dot.dataset.c === color) dot.classList.add('on-' + color);\n  });\n}\n\nfunction applyPhase(p) {\n  tlGroups.ns.forEach(el => lightBox(el, p.ns));\n  tlGroups.ew.forEach(el => lightBox(el, p.ew));\n  nsState = p.ns;\n  ewState = p.ew;\n}\n\napplyPhase(PHASES[0]);   // initialise\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   CAR DEFINITIONS\n   \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n   Lane positions (road centre = 300, RW = 160):\n     LR lane 1 \u2192 y = 312  (bottom half \u00b7 inner lane)\n     LR lane 2 \u2192 y = 346  (bottom half \u00b7 outer lane)\n     RL lane 1 \u2192 y = 232  (top half \u00b7 inner lane)\n     RL lane 2 \u2192 y = 266  (top half \u00b7 outer lane)\n     TB lane 1 \u2192 x = 312\n     TB lane 2 \u2192 x = 346\n     BT lane 1 \u2192 x = 232\n     BT lane 2 \u2192 x = 266\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\nconst CAR_DEFS = [\n  { id:'carA1', axis:'EW', dir:'LR', x: -50, y: 312, spd: 150 },\n  { id:'carA2', axis:'EW', dir:'LR', x:-290, y: 346, spd:  90 },\n  { id:'carB1', axis:'EW', dir:'RL', x: 640, y: 232, spd: 124 },\n  { id:'carB2', axis:'EW', dir:'RL', x: 870, y: 266, spd: 100 },\n  { id:'carC1', axis:'NS', dir:'TB', x: 312, y: -50, spd: 132 },\n  { id:'carC2', axis:'NS', dir:'TB', x: 346, y:-290, spd:  93 },\n  { id:'carD1', axis:'NS', dir:'BT', x: 232, y: 640, spd: 115 },\n  { id:'carD2', axis:'NS', dir:'BT', x: 266, y: 870, spd:  79 },\n];\n\nconst cars = CAR_DEFS.map(d => ({\n  ...d,\n  el: document.getElementById(d.id),\n  braking: false,\n}));\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   SMOOTH APPROACH HELPER\n   Within 55 px of the stop line the car decelerates so it\n   eases to a halt rather than snapping to the position.\n   Returns the px to advance this frame.\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\nfunction approach(dist, maxSpd) {\n  if (dist <= 0) return 0;\n  const factor = dist < 55 ? (dist / 55) * 0.95 + 0.05 : 1;\n  return Math.min(maxSpd * factor, dist);\n}\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   CAR MOVEMENT\n   Stop rule: a car stops only if its light is red/amber AND\n   it has not yet reached (or passed) the stop line.\n   Once a car commits past the stop line it ignores the light\n   and clears the intersection \u2014 same as real traffic.\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\nfunction moveCar(car, dt) {\n  const state  = car.axis === 'NS' ? nsState : ewState;\n  const isRed  = state === 'red' || state === 'amber';\n  const spd    = car.spd * dt;   // px to move this frame\n\n  switch (car.dir) {\n\n    /* \u2500\u2500 Left \u2192 Right \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n    case 'LR': {\n      if (isRed && car.x <= SX_LR) {\n        // Approaching or at stop line while red \u2192 ease to halt\n        car.x += approach(SX_LR - car.x, spd);\n      } else {\n        // Green, or already past stop line (committed) \u2192 go\n        car.x += spd;\n      }\n      car.braking = isRed && car.x >= SX_LR - 1;\n      if (car.x > SW + 55) { car.x = -(CW + 10); car.braking = false; }\n      break;\n    }\n\n    /* \u2500\u2500 Right \u2192 Left \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n    case 'RL': {\n      if (isRed && car.x >= SX_RL) {\n        car.x -= approach(car.x - SX_RL, spd);\n      } else {\n        car.x -= spd;\n      }\n      car.braking = isRed && car.x <= SX_RL + 1;\n      if (car.x < -(CW + 55)) { car.x = SW + 55; car.braking = false; }\n      break;\n    }\n\n    /* \u2500\u2500 Top \u2192 Bottom \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n    case 'TB': {\n      if (isRed && car.y <= SY_TB) {\n        car.y += approach(SY_TB - car.y, spd);\n      } else {\n        car.y += spd;\n      }\n      car.braking = isRed && car.y >= SY_TB - 1;\n      if (car.y > SH + 55) { car.y = -(VH + 10); car.braking = false; }\n      break;\n    }\n\n    /* \u2500\u2500 Bottom \u2192 Top \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n    case 'BT': {\n      if (isRed && car.y >= SY_BT) {\n        car.y -= approach(car.y - SY_BT, spd);\n      } else {\n        car.y -= spd;\n      }\n      car.braking = isRed && car.y <= SY_BT + 1;\n      if (car.y < -(VH + 55)) { car.y = SH + 55; car.braking = false; }\n      break;\n    }\n  }\n\n  // GPU-accelerated position + brake indicator\n  car.el.style.transform = `translate(${car.x}px,${car.y}px)`;\n  car.el.classList.toggle('braking', car.braking);\n}\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   MAIN LOOP\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\nconst startTs = performance.now();\nlet   lastTs  = null;\n\nfunction tick(ts) {\n  if (!lastTs) lastTs = ts;\n  const dt = Math.min((ts - lastTs) / 1000, 0.05);  // seconds; capped at 50 ms\n  lastTs = ts;\n\n  // \u2500 Traffic light phase \u2500\n  const elapsed  = (ts - startTs) % CYCLE;\n  let   phaseIdx = 0;\n  for (let i = PHASES.length - 1; i >= 0; i--) {\n    if (elapsed >= PHASES[i].t) { phaseIdx = i; break; }\n  }\n  if (phaseIdx !== lastPhaseIdx) {\n    lastPhaseIdx = phaseIdx;\n    applyPhase(PHASES[phaseIdx]);\n  }\n\n  // \u2500 Move every car \u2500\n  for (const car of cars) moveCar(car, dt);\n\n  requestAnimationFrame(tick);\n}\n\nrequestAnimationFrame(tick);\n</script>\n</body>\n</html>\n    \n  </body>\n  \n</html>\n"}