{"index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Color Gradient Animation</title>\n    <link rel=\"stylesheet\" href=\"./style.css\">\n\n  </head>\n    \n  <body>\n  <div class=\"container\">\n\t<div class=\"bgColor\">\n\t\t<div class=\"ray\"></div>\n\t\t<div class=\"ray\"></div>\n\t\t<div class=\"ray\"></div>\n\t</div>\n\t<div class=\"bgColor2\">\n\n\t</div>\n\t<div class=\"bgColor3\">\n\t\t<div class=\"ray2\"></div>\n\t\t<div class=\"ray2\"></div>\n\n\t\t<div class=\"ray2\"></div>\n\t</div>\n\n\t<div class=\"bgColor5\">\n\n\t</div>\n\t<div class=\"bgColor6\">\n\n\t</div>\n\t<ul>\n\t\t<li>AliceBlue</li>\n\t\t<li>AntiqueWhite</li>\n\t\t<li>Aqua</li>\n\t\t<li>Aquamarine</li>\n\t\t<li>Azure</li>\n\t\t<li>Beige</li>\n\t\t<li>Bisque</li>\n\t\t<li>Black</li>\n\t\t<li>BlanchedAlmond</li>\n\t\t<li>Blue</li>\n\t\t<li>BlueViolet</li>\n\t\t<li>Brown</li>\n\t\t<li>BurlyWood</li>\n\t\t<li>CadetBlue</li>\n\t\t<li>Chartreuse</li>\n\t\t<li>Chocolate</li>\n\t\t<li>Coral</li>\n\t\t<li>CornflowerBlue</li>\n\t\t<li>Cornsilk</li>\n\t\t<li>Crimson</li>\n\t\t<li>Cyan</li>\n\t\t<li>DarkBlue</li>\n\t\t<li>DarkCyan</li>\n\t\t<li>DarkGoldenRod</li>\n\t\t<li>DarkGray</li>\n\t\t<li>DarkGrey</li>\n\t\t<li>DarkGreen</li>\n\t\t<li>DarkKhaki</li>\n\t\t<li>DarkMagenta</li>\n\t\t<li>DarkOliveGreen</li>\n\t\t<li>DarkOrange</li>\n\t\t<li>DarkOrchid</li>\n\t\t<li>DarkRed</li>\n\t\t<li>DarkSalmon</li>\n\t\t<li>DarkSeaGreen</li>\n\t\t<li>DarkSlateBlue</li>\n\t\t<li>DarkSlateGray</li>\n\t\t<li>DarkSlateGrey</li>\n\t\t<li>DarkTurquoise</li>\n\t\t<li>DarkViolet</li>\n\t\t<li>DeepPink</li>\n\t\t<li>DeepSkyBlue</li>\n\t\t<li>DimGray</li>\n\t\t<li>DimGrey</li>\n\t\t<li>DodgerBlue</li>\n\t\t<li>FireBrick</li>\n\t\t<li>FloralWhite</li>\n\t\t<li>ForestGreen</li>\n\t\t<li>Fuchsia</li>\n\t\t<li>Gainsboro</li>\n\t\t<li>GhostWhite</li>\n\t\t<li>Gold</li>\n\t\t<li>GoldenRod</li>\n\t\t<li>Gray</li>\n\t\t<li>Grey</li>\n\t\t<li>Green</li>\n\t\t<li>GreenYellow</li>\