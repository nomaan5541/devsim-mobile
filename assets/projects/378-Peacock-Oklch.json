{"index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Peacock oklch</title>\n    \n\n  </head>\n    \n  <body>\n  <!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        :root {\n           \n            --bg-sky: oklch(95% 0.06 200); /* Soft sky blue */\n            --sun-glow: oklch(98% 0.12 95); /* Bright sun yellow */\n            --grass-base: oklch(65% 0.18 145); /* Lush meadow green */\n            \n            /* Peacock Palette */\n            --navy: oklch(35% 0.18 260);\n            --teal: oklch(65% 0.15 185);\n            --barb: oklch(from var(--teal) calc(l - 0.1) calc(c + 0.05) h);\n            --cyan: oklch(80% 0.12 200);\n            --gold: oklch(75% 0.18 70);\n            --eye-dark: oklch(25% 0.15 270);\n            --stem: oklch(from var(--teal) calc(l - 0.2) c h);\n            --shadow: oklch(0% 0 0 / 0.15);\n            --shadow-dark: oklch(0% 0 0 / 0.3);\n\n            /* Garden Colors */\n            --flower-pink: oklch(75% 0.2 350);\n            --flower-yellow: oklch(90% 0.18 90);\n            --flower-orange: oklch(75% 0.2 50);\n            --leaf-green: oklch(55% 0.15 140);\n\n            /* Base Values in OKLCH */\n            --white: oklch(100% 0 0);\n            --black: oklch(0% 0 0);\n            --transparent: oklch(0% 0 0 / 0);\n        }\n\n        body {\n            background: radial-gradient(\n                circle at 50% 30%, \n                var(--sun-glow) 0%, \n                var(--bg-sky) 60%,\n                var(--grass-base) 100%\n            );\n            background-attachment: fixed;\n            margin: 0;\n            height: 100vh;\n            display: grid;\n            place-items: center;\n            overflow: hidden;\n          overflow-y:auto;\n            font-family: sans-serif;\n        }\n\n        .artboard {\n            position: relative;\n            width: 800px;\n            height: 600px;\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            padding-bottom: 150px;\n        }\n\n        /* --- MEADOW GENERATOR --- */\n        .meadow {\n            position: absolute;\n            inset: 0;\n            z-index: 0;\n            pointer-events: none;\n        }\n\n        /* Clouds */\n        .cloud {\n            position: absolute;\n            top: var(--t, 50px);\n            left: var(--l, 10%);\n            width: 120px;\n            height: 40px;\n            background: var(--white);\n            border-radius: 50px;\n            filter: blur(15px);\n            opacity: 0.6;\n            animation: drift 60s linear infinite;\n        }\n\n        @keyframes drift {\n            from { transform: translateX(-200px); }\n            to { transform: translateX(1000px); }\n        }\n\n        /* --- PEACOCK FEATHER ENGINE --- */\n        .tail-system {\n            position: absolute;\n            bottom: 240px;\n            display: flex;\n            justify-content: center;\n        }\n\n        .feather {\n            position: absolute;\n            bottom: 0;\n            width: 80px;\n            height: 320px;\n            transform-origin: bottom center;\n            transform: \n                rotate(calc( (var(--i) - (var(--total) / 2)) * var(--spread) )) \n                scale(var(--row-scale));\n            \n            background: \n                linear-gradient(90deg, \n                    var(--transparent) 48%, \n                    var(--stem) 49%, \n                    var(--stem) 51%, \n                    var(--transparent) 52%\n                ),\n                repeating-linear-gradient(\n                    45deg, \n                    var(--transparent) 0px, \n                    var(--transparent) 3px, \n                    var(--barb) 4px, \n                    var(--transparent) 5px\n                ),\n                repeating-linear-gradient(\n                    -45deg, \n                    var(--transparent) 0px, \n                    var(--transparent) 3px, \n                    var(--barb) 4px, \n                    var(--transparent) 5px\n                ),\n                var(--teal);\n\n            background-size: 100% 100%, 50% 100%, 50% 100%, 100% 100%;\n            background-position: center, left center, right center, center;\n            background-repeat: no-repeat;\n            border-radius: 40px 40px 10px 10px;\n            border: 1px solid var(--shadow);\n            box-shadow: 4px 4px 12px var(--shadow);\n            animation: featherSway 3s ease-in-out infinite alternate;\n            animation-delay: calc(var(--i) * -0.3s);\n        }\n\n        @keyframes featherSway {\n            0% { transform: rotate(calc( (var(--i) - (var(--total) / 2)) * var(--spread) )) scale(var(--row-scale)); }\n            100% { transform: rotate(calc( ((var(--i) - (var(--total) / 2)) * var(--spread)) + 1.5deg )) scale(calc(var(--row-scale) * 1.02)); }\n        }\n\n        .feather::after {\n            content: '';\n            position: absolute;\n            top: 15px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 50px;\n            height: 65px;\n            border-radius: 50% 50% 45% 45%;\n            background: radial-gradient(\n                circle at center,\n                var(--eye-dark) 0% 25%,\n                var(--cyan) 26% 45%,\n                var(--gold) 46% 75%,\n                var(--transparent) 76%\n            );\n            box-shadow: 0 4px 10px var(--shadow-dark);\n        }\n\n        .row-back  { --row-scale: 1.1; --spread: 18deg; --total: 10; z-index: 1; }\n        .row-mid   { --row-scale: 0.9; --spread: 22deg; --total: 8;  z-index: 2; }\n        .row-front { --row-scale: 0.7; --spread: 28deg; --total: 6;  z-index: 3; }\n\n        /* --- PEACOCK BODY SECTION --- */\n        .peacock-body {\n            position: relative;\n            z-index: 10;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        .neck {\n            width: 30px;\n            height: 90px;\n            background: var(--navy);\n            border-radius: 100% 20% 0 0 / 100% 40% 0 0;\n            transform: rotate(-3deg) skewX(-8deg);\n            position: relative;\n            margin-bottom: -15px;\n            z-index: 2;\n            animation: headMove 4s ease-in-out infinite;\n            box-shadow: inset -6px 0 10px oklch(0% 0 0 / 0.3);\n        }\n\n        @keyframes headMove {\n            0%, 100% { transform: rotate(-3deg) skewX(-8deg); }\n            50% { transform: rotate(1deg) skewX(-4deg) translateY(-2px); }\n        }\n\n        .head {\n            width: 60px;\n            height: 50px;\n            background: var(--navy);\n            border-radius: 50% 50% 50% 50% / 60% 65% 60% 60% ;\n            position: absolute;\n            top: -40px;\n            left: -5px;\n            box-shadow: 2px 3px 6px var(--shadow-dark), inset 4px 4px 8px oklch(100% 0 0 / 0.1);\n        }\n\n        .crest {\n            position: absolute;\n            top: -24px;\n            left: 50%;\n            transform: translateX(-50%);\n            display: flex;\n            gap: 4px;\n        }\n\n        .crest-item {\n           width: 2px;\n  height: 25px;\n  background: var(--navy);\n  position: relative;\n  box-shadow: 1px 1px 2px var(--shadow);\n  transform: rotate(-12deg);\n  margin-right: 3px;\n        }\n\n        .crest-item::before {\n            content: '';\n            position: absolute;\n            top: -6px;\n            left: -4px;\n            width: 10px;\n            height: 10px;\n            background: var(--eye-dark);\n            border-radius: 50%;\n            box-shadow: 0 2px 3px var(--shadow);\n        }\n\n        .face-detail {\n            position: absolute;\n            width: 25px;\n            height: 29px;\n            background: var(--white);\n            border-radius: 0 50px;\n            top: 11px;\n            right: 3px;\n            transform: rotate(-35deg);\n            box-shadow: inset 1px -1px 3px var(--shadow);\n        }\n\n        .eye-pupil {\n            position: absolute;\n            width: 15px;\n            height: 10px;\n            background: oklch(85% 0.18 90); /* OKLCH Gold variant */\n            border-radius: 50%;\n            top: 10px;\n            right: 5px;\n            transform: rotate(45deg);\n        }\n\n        .eye-pupil::before {\n            content: '';\n            position: absolute;\n            width: 6px;\n            height: 6px;\n            background: var(--black);\n            border-radius: 50%;\n            top: 2px;\n            right: 1px;\n        }\n\n        .beak {\n            position: absolute;\n  right: -23px;\n  top: 25px;\n  width: 25px;\n  height: 14px;\n  background: oklch(from var(--gold) calc(l - 0.2) c h);\n  clip-path: polygon(0 0, 100% 50%, 0 100%);\n  filter: drop-shadow(1px 2px 2px var(--shadow-dark));\n  transform: rotate(5deg);\n        }\n\n        .torso {\n            width: 90px;\n            height: 140px;\n            background: var(--navy);\n            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;\n            z-index:3;\n            margin-top: -10px;\n            overflow: hidden;\n            position: relative;\n           \n            border: 1px solid var(--shadow);\n            animation: breathe 3s ease-in-out infinite;\n            box-shadow: inset -15px -15px 30px oklch(0% 0 0 / 0.4), inset 10px 10px 20px oklch(100% 0 0 / 0.05), 0 10px 25px var(--shadow-dark);\n        }\n\n        @keyframes breathe {\n            0%, 100% { transform: scale(1); }\n            50% { transform: scale(1.04); }\n        }\n\n        .peacock-petals {\n            width: 170px;\n            aspect-ratio: 1;\n            --g: /13.528% 13.528% radial-gradient(var(--black) calc(71% - 1px), var(--transparent) 71%) no-repeat;\n            mask: 100% 50% var(--g),97.553% 65.451% var(--g),90.451% 79.389% var(--g),79.389% 90.451% var(--g),65.451% 97.553% var(--g),50% 100% var(--g),34.549% 97.553% var(--g),20.611% 90.451% var(--g),9.549% 79.389% var(--g),2.447% 65.451% var(--g),0% 50% var(--g),2.447% 34.549% var(--g),9.549% 20.611% var(--g),20.611% 9.549% var(--g),34.549% 2.447% var(--g),50% 0% var(--g),65.451% 2.447% var(--g),79.389% 9.549% var(--g),90.451% 20.611% var(--g),97.553% 34.549% var(--g),radial-gradient(100% 100%, var(--black) 42.704%, var(--transparent) calc(42.704% + 1px));\n            background-color: oklab(0.8 -0.04 -0.08); \n            z-index: -1;\n            position: absolute;\n            bottom: 50px;\n            filter: drop-shadow(0 5px 10px var(--shadow-dark));\n        }\n      \n        .legs {\n            display: flex;\n            gap: 40px;\n            margin-top: -10px;\n            z-index:-1\n        }\n\n        .leg {\n            width: 6px;\n            height: 60px;\n            background: oklch(from var(--gold) calc(l - 0.1) 0.05 h);\n            position: relative;\n            box-shadow: inset -1px 0 2px oklch(0% 0 0 / 0.3);\n        }\n\n        .foot {\n            position: absolute;\n            bottom: -18px;\n            transform: translateX(-50%);\n            width: 4px;\n            height: 22px;\n            background-color: oklch(from var(--gold) calc(l - 0.1) 0.05 h);\n            border-radius: 2px;\n            z-index: 11;\n            box-shadow: 1px 1px 2px var(--shadow);\n        }\n        \n        .left-foot{ transform:rotate(15deg); left:-1px }\n        .right-foot{ transform:rotate(-15deg); right:-1px }\n        \n        .foot::before, .foot::after {\n            position: absolute;\n            content: '';    \n            top: 0;\n            width: 4px;\n            height: 18px;\n            background: inherit;\n            border-radius: 2px;\n            transform-origin: top center;\n            box-shadow: inset -1px 0 1px oklch(0% 0 0 / 0.2);\n        }\n        .foot::before { left: 0; transform: rotate(40deg); }\n        .foot::after { left: 0; transform: rotate(-40deg); }\n\n        .ground-shadow {\n            position: absolute;\n            bottom: 140px;\n            width: 450px;\n            height: 60px;\n            background: var(--shadow-dark);\n            border-radius: 50%;\n            filter: blur(15px);\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"artboard\">\n    <div class=\"meadow\">\n        <div class=\"cloud\" style=\"--t: 40px; --l: 10%\"></div>\n        <div class=\"cloud\" style=\"--t: 80px; --l: 60%; animation-delay: -30s;\"></div>\n    </div>\n\n    <div class=\"ground-shadow\"></div>\n\n    <div class=\"tail-system row-back\">\n        <div class=\"feather\" style=\"--i:0\"></div><div class=\"feather\" style=\"--i:1\"></div>\n        <div class=\"feather\" style=\"--i:2\"></div><div class=\"feather\" style=\"--i:3\"></div>\n        <div class=\"feather\" style=\"--i:4\"></div><div class=\"feather\" style=\"--i:5\"></div>\n        <div class=\"feather\" style=\"--i:6\"></div><div class=\"feather\" style=\"--i:7\"></div>\n        <div class=\"feather\" style=\"--i:8\"></div><div class=\"feather\" style=\"--i:9\"></div>\n        <div class=\"feather\" style=\"--i:10\"></div>\n    </div>\n\n    <div class=\"tail-system row-mid\">\n        <div class=\"feather\" style=\"--i:0\"></div><div class=\"feather\" style=\"--i:1\"></div>\n        <div class=\"feather\" style=\"--i:2\"></div><div class=\"feather\" style=\"--i:3\"></div>\n        <div class=\"feather\" style=\"--i:4\"></div><div class=\"feather\" style=\"--i:5\"></div>\n        <div class=\"feather\" style=\"--i:6\"></div><div class=\"feather\" style=\"--i:7\"></div>\n        <div class=\"feather\" style=\"--i:8\"></div>\n    </div>\n\n    <div class=\"tail-system row-front\">\n        <div class=\"feather\" style=\"--i:0\"></div><div class=\"feather\" style=\"--i:1\"></div>\n        <div class=\"feather\" style=\"--i:2\"></div><div class=\"feather\" style=\"--i:3\"></div>\n        <div class=\"feather\" style=\"--i:4\"></div><div class=\"feather\" style=\"--i:5\"></div>\n        <div class=\"feather\" style=\"--i:6\"></div>\n    </div>\n\n    <div class=\"peacock-body\">\n        <div class=\"neck\">\n            <div class=\"head\">\n                <div class=\"crest\">\n                    <div class=\"crest-item\"></div>\n                    <div class=\"crest-item\"></div>\n                    <div class=\"crest-item\"></div>\n                </div>\n                <div class=\"face-detail\">\n                    <div class=\"eye-pupil\"></div>\n                </div>\n                <div class=\"beak\"></div>\n            </div>\n        </div>\n        <div class=\"torso\"></div>\n        <div class=\"peacock-petals\"></div> \n        <div class=\"legs\">\n            <div class=\"leg\"><div class=\"foot left-foot\"></div></div>\n            <div class=\"leg\"><div class=\"foot right-foot\"></div></div>\n        </div>\n    </div>\n</div>\n\n</body>\n</html>\n    \n  </body>\n  \n</html>\n"}